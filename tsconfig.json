{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["node"],

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",

    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmitOnError": false
  },
  "include": [
    "src/reactivity-graph",
    "src/static",
    "src/open-in-editor.ts",
    "src/vite-plugin.ts"
  ],
  "exclude": ["node_modules", "dist", "test", "src/App.vue", "src/main.ts"]
}
